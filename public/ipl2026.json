  "storylines": [
    {
      "id": "rr-4-0",
      "title": "RR 4-from-4 \u2014 perfect start as Sooryavanshi and Bishnoi dominate",
      "body": "Rajasthan Royals have a perfect 4-0 record and sit top of the table with 8 points after chasing down 202 vs RCB in Match 16 at Guwahati. The teenager Vaibhav Sooryavanshi (PoM) smashed 78 off 29 with a 15-ball fifty, while Dhruv Jurel scored an unbeaten 81. Ravi Bishnoi castled Virat Kohli and now has 9 wickets leading the Purple Cap.",
      "tag": "On Fire"
    },
    {
      "id": "suryavanshi-orange",
      "title": "Vaibhav Sooryavanshi takes Orange Cap \u2014 200 runs at SR 266",
      "body": "The 14-year-old sensation has taken over the Orange Cap after his explosive 78 off 29 balls vs RCB in Match 16. Sooryavanshi now has 200 runs in 4 innings at an astonishing strike rate of 266 and average of 50. His 15-ball fifty vs RCB was his second of the season after 52 off 17 on debut vs CSK.",
      "tag": "Sensation"
    },
    {
      "id": "bishnoi-purple",
      "title": "Ravi Bishnoi extends Purple Cap lead \u2014 9 wickets including Kohli scalp",
      "body": "Ravi Bishnoi remains the Purple Cap leader with 9 wickets in 4 innings. His biggest moment came in Match 16 when he bowled Virat Kohli for 32. Bishnoi's earlier 4/41 vs GT in Match 9 set the tone for his tournament-leading campaign.",
      "tag": "On Fire"
    },
    {
      "id": "gt-dc-thriller",
      "title": "GT snatch first win in last-ball thriller vs DC \u2014 Match 14",
      "body": "Gujarat Titans, winless in their first 2 games, pulled off a stunning 1-run victory over Delhi Capitals in Match 14 at the Arun Jaitley Stadium. DC needed 2 off the last ball and could only manage a single. GT's first points of IPL 2026, while DC suffered their first loss after starting 2-0.",
      "tag": "Breakout"
    },
    {
      "id": "kkr-crisis",
      "title": "KKR winless from 4 matches — Rs.25.2Cr Green and big buys failing",
      "body": "Kolkata Knight Riders remain the only team without a win, going 0-3 with 1 washout from 4 matches. The 3-wicket loss to LSG in Match 15 at Eden Gardens deepened their crisis. Cameron Green (Rs.25.2Cr) and other expensive auction buys have failed to deliver, leaving KKR bottom with just 1 point.",
      "tag": "Crisis"
    },
    {
      "id": "gt-breakthrough",
      "title": "GT snatch first win in last-ball thriller vs DC — Match 14 stunner",
      "body": "Gujarat Titans finally broke their duck with a heart-stopping 1-run victory over Delhi Capitals in Match 14 at Delhi. After losing their first two games, GT defended 210 as DC fell just short needing 2 off the final ball. The victory lifted GT off the bottom and into the playoff conversation.",
      "tag": "Breakout"
