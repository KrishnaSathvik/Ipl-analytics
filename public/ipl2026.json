  "storylines": [
    {
      "id": "srh-end-rr-perfect-streak",
      "title": "SRH crush RR by 57 runs to end their perfect start — Ishan Kishan 91 & debutants Praful Hinge, Sakib Hussain take 4 each",
      "body": "Sunrisers Hyderabad bounced back from three straight losses with a dominant 57-run victory over table-toppers Rajasthan Royals on April 13. Captain Ishan Kishan's 91 off 51 balls helped SRH post 216/6, before debutants Praful Hinge (4/31) and Sakib Hussain (4/28) shared 8 wickets to bowl out RR for just 159. The loss ended RR's perfect 4-0 start but they remain top with 8 points.",
      "tag": "Breakout"
    },
    {
      "id": "prasidh-purple-cap-dominance",
      "title": "Prasidh Krishna storms to Purple Cap lead with 10 wickets — 4/28 vs LSG makes him tournament's most lethal bowler",
      "body": "Gujarat Titans pacer Prasidh Krishna has seized control of the Purple Cap race with 10 wickets from just 4 matches. His Player-of-the-Match 4/28 against LSG on April 12, including key scalps of Markram, Badoni, and Pooran, helped GT restrict LSG to 164/8 and secure a 7-wicket win. Krishna now leads RR's Ravi Bishnoi (9 wickets) in the bowling charts.",
      "tag": "On Fire"
    },
    {
      "id": "vaibhav-orange-cap-teenage-sensation",
      "title": "Vaibhav Sooryavanshi holds Orange Cap at 15 — 200 runs at strike rate of 255 makes him IPL's youngest batting star",
      "body": "Rajasthan Royals' 15-year-old opener Vaibhav Sooryavanshi continues to lead the Orange Cap standings with 200 runs from 5 innings. Despite a rare failure (13 off 8) in RR's first loss against SRH on April 13, the teenager maintains his incredible strike rate of 255.32. His scores of 52, 31, 39, and 78 have made him the breakout star of IPL 2026.",
      "tag": "Sensation"
    },
    {
      "id": "kkr-crisis-deepens-no-wins",
      "title": "KKR's nightmare continues — still 0 wins after 21 matches, Rs.25.2Cr Cameron Green and big buys failing to deliver",
      "body": "Kolkata Knight Riders remain the only team without a single win on the field after 21 matches in IPL 2026. Despite spending Rs.25.2 crore on Cameron Green and Rs.18 crore on Matheesha Pathirana, KKR sit bottom with just 1 point from a washout. They face CSK at Chepauk on April 14, desperately needing their first victory to avoid becoming the worst start in IPL history.",
      "tag": "Crisis"
    },
    {
      "id": "sanju-samson-csk-maiden-century",
      "title": "Sanju Samson's maiden CSK century breaks losing streak — 115* off 47 balls powers CSK to first win vs DC",
      "body": "Chennai Super Kings finally got off the mark in IPL 2026 with Sanju Samson's stunning unbeaten 115 off 47 balls against Delhi Capitals on April 11. The innings, which included 12 fours and 8 sixes, helped CSK post 212/2 and secure a 23-run victory. It was the first century of IPL 2026 and ended CSK's three-match losing streak to start the season.",
      "tag": "Historic"
    },
    {
      "id": "patidar-salt-rcb-wankhede-masterclass",
      "title": "Patidar and Salt demolish MI at Wankhede — 53 off 20 balls and 78 off 36 power RCB to 240/4 in 18-run win",
      "body": "Royal Challengers Bengaluru produced a batting masterclass at the Wankhede on April 12, posting 240/4 to defeat Mumbai Indians by 18 runs. Captain Rajat Patidar's brutal 53 off 20 balls, combined with Phil Salt's 78 off 36 and Virat Kohli's 50 off 38, helped RCB reach their highest Wankhede total. The win moved RCB to 3rd place with 6 points.",
      "tag": "On Fire"
    }
