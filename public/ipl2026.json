  "storylines": [
    {
      "id": "pbks-take-top-spot",
      "title": "PBKS grab top spot — Prabhsimran 83* & Iyer 66 stitch 139 to shrug off de Kock's 112*",
      "body": "Punjab Kings are the new table-toppers after their 7-wicket win at Wankhede on April 16. Chasing 196, openers Prabhsimran Singh (83* off 60) and captain Shreyas Iyer (66 off 41) put on 139 in just 67 balls to nullify a stunning Quinton de Kock 112* off 60 balls for MI. PBKS are now 4-0 on the pitch with one washout, 9 points and a +1.067 NRR at the summit.",
      "tag": "On Fire"
    },
    {
      "id": "srh-end-rr-unbeaten-run",
      "title": "SRH end RR's 4-0 run — Ishan Kishan 91 off 44, Hinge & Hussain star on debut",
      "body": "Sunrisers Hyderabad ended the Royals' unbeaten streak with a crushing 57-run win at the Rajiv Gandhi Stadium on April 13. Ishan Kishan blitzed 91 off 44 as SRH posted 216/6. Then debutants Praful Hinge (4/34, PoM) and Sakib Hussain (4/24) tore through a 159 all-out reply — Hinge's three wickets in his opening over were the first such instance in 18 seasons of IPL.",
      "tag": "Historic"
    },
    {
      "id": "rcb-climb-to-second",
      "title": "RCB climb to No. 2 — 4 wins in 5 as Rasikh Dar 4/24 dismantles LSG",
      "body": "Royal Challengers Bengaluru are surging after chasing 147 with 29 balls to spare at Chinnaswamy on April 15. Rasikh Salam Dar's career-best 4/24 bowled out LSG for 146; Virat Kohli's 49(34) and Rajat Patidar's 27(13) did the rest. RCB are 2nd with 8 points and a massive +1.503 NRR, level on points with RR but ahead on run-rate.",
      "tag": "On Fire"
    },
    {
      "id": "kohli-takes-orange-cap",
      "title": "Kohli grabs the Orange Cap — 228 runs in 5, edges Klaasen & own skipper Patidar",
      "body": "Virat Kohli leads the IPL 2026 run charts with 228 runs at average 57 and strike rate 158.33 after 5 innings. Right behind him are SRH's Heinrich Klaasen (224) and RCB captain Rajat Patidar (222), making it the tightest Orange Cap race in years. Patidar has hit a tournament-high 21 sixes, while Kishan (213) and Prabhsimran (211 in 4 inns) round out a top 5 separated by just 17 runs.",
      "tag": "Sensation"
    },
    {
      "id": "prasidh-kamboj-tied-purple",
      "title": "Prasidh & Kamboj tied on 10 wkts — Prince Yadav's 9 puts three pacers within one strike",
      "body": "GT's Prasidh Krishna and CSK's Anshul Kamboj are joint Purple Cap leaders with 10 wickets apiece; LSG's Prince Yadav is hot on their heels with 9. Prasidh is far ahead on average (15.2 vs Kamboj's 18.9) after his 4/28 vs LSG. Ravi Bishnoi (9 wkts, avg 16.56) and Jofra Archer (7, econ 8.47) keep RR in the hunt from both ends.",
      "tag": "Breakout"
    },
