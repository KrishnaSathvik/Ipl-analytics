  "storylines": [
    {
      "id": "rr-perfect-start-continues",
      "title": "RR extend perfect start to 4-0 — Sooryavanshi leads Orange Cap race after RCB scalping",
      "body": "Rajasthan Royals maintained their perfect record with a 6-wicket win over defending champions RCB in Match 16 on April 10. Vaibhav Sooryavanshi's explosive 78 off 29 balls and Dhruv Jurel's unbeaten 81 powered the chase of 202. The teenager now leads the Orange Cap with 200 runs at a stunning strike rate of 266.67, while Ravi Bishnoi dismissed Virat Kohli to maintain his Purple Cap lead with 9 wickets.",
      "tag": "On Fire"
    },
    {
      "id": "pbks-unbeaten-streak",
      "title": "PBKS maintain unbeaten streak — Shreyas Iyer's captaincy shines in 220+ chase against SRH",
      "body": "Punjab Kings showcased their championship credentials with a clinical 6-wicket victory over SRH in Match 17 on April 11, chasing down 220 with 7 balls to spare. Captain Shreyas Iyer led from the front with 68 runs, maintaining PBKS's unbeaten record with 3 wins and 1 washout from 4 matches, sitting second with 7 points.",
      "tag": "On Fire"
    },
    {
      "id": "samson-breaks-csk-drought",
      "title": "Sanju Samson ends CSK's nightmare — maiden IPL 2026 century breaks winless streak",
      "body": "Chennai Super Kings finally got off the mark in IPL 2026 with a dominant 23-run victory over DC in Match 18 on April 11. Sanju Samson silenced critics with the tournament's first century (115* off 56 balls), ending his poor form and CSK's three-match losing streak. The victory moved CSK from bottom to ninth place with their first 2 points.",
      "tag": "Breakout"
    },
    {
      "id": "kkr-crisis-deepens-further",
      "title": "KKR's nightmare continues — 0 wins from 4 matches despite Rs.25.2Cr Cameron Green investment",
      "body": "Kolkata Knight Riders remain the only team without a win after their 3-wicket loss to LSG in Match 15 on April 9. Despite Cameron Green's record Rs.25.2 crore price tag and big-money additions, KKR sit bottom with just 1 point from a washout against PBKS in Match 12. Their expensive buys have failed to deliver as the crisis deepens.",
      "tag": "Crisis"
    },
    {
      "id": "bishnoi-purple-domination",
      "title": "Ravi Bishnoi dominates Purple Cap — 9 wickets including Virat Kohli scalp in RR's perfect run",
      "body": "RR's Ravi Bishnoi continues to lead the Purple Cap race with 9 wickets in 4 matches at an average of 12.66. His biggest moment came in Match 16 when he clean bowled Virat Kohli for 32. His figures of 1/16, 4/41, 2/25, and 2/32 have been instrumental in RR's unbeaten 4-0 start to IPL 2026.",
      "tag": "On Fire"
    },
    {
      "id": "sooryavanshi-orange-cap-teen",
      "title": "15-year-old Vaibhav Sooryavanshi leads Orange Cap — redefining T20 batting at 266+ SR",
      "body": "Vaibhav Sooryavanshi has taken cricket by storm, topping the Orange Cap standings with 200 runs in 4 innings at a mind-boggling strike rate of 266.67. After his debut 52 off 17 against CSK in Match 3, his latest 78 off 29 against RCB in Match 16 showcased fearless strokeplay that's redefining T20 cricket for his generation.",
      "tag": "Sensation"
    }
  ],
