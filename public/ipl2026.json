  "storylines": [
    {
      "id": "dc-stun-rcb-match-26",
      "title": "DC stun RCB at Chinnaswamy — Miller 22(10) seals an epic rescue from 18/3",
      "body": "Delhi Capitals pulled off a stunning 6-wicket win at Chinnaswamy on April 18. Reeling at 18/3 early in the chase of 176, KL Rahul (57 off 34, PoM) and Tristan Stubbs (60*) rebuilt before David Miller blasted 22 off 10 balls (1 four, 2 sixes) to finish the job when 15 were needed off the last over from Romario Shepherd. Phil Salt's 50(30) had anchored RCB to 175/8 but DC's death bowling restricted them to just 29 in the last 5 overs. RCB slip to 4-2 but stay 2nd on NRR (+1.171); DC climb to 5th with 3 wins from 5.",
      "tag": "Sensation"
    },
    {
