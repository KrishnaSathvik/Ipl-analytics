  "storylines": [
    {
      "id": "rcb-wankhede-masterclass",
      "title": "RCB rout MI at Wankhede — Salt, Patidar & Kohli fifties power 240/4 in 18-run win",
      "body": "Royal Challengers Bengaluru stormed back to form with a clinical 18-run win over Mumbai Indians at the Wankhede on April 12. Phil Salt (78 off 36) and Virat Kohli (50 off 38) stitched a 120-run opening stand, before captain Rajat Patidar's brutal 53 off 20 balls took RCB to 240/4 — one of their highest Wankhede totals. Sherfane Rutherford's 71* off 31 wasn't enough as MI finished 222/5. RCB climb to 3rd with 6 points and a +1.148 NRR.",
      "tag": "On Fire"
    },
    {
      "id": "prasidh-seizes-purple-cap",
      "title": "Prasidh Krishna grabs Purple Cap — 4/28 vs LSG lifts GT pacer to 10 wickets, overtakes Bishnoi",
      "body": "Gujarat Titans' Prasidh Krishna produced a Player-of-the-Match 4/28 against LSG in Match 19 on April 12, including the key scalps of Markram, Badoni, Pooran and Choudhary. He is now the Purple Cap leader with 10 wickets in 4 games, leapfrogging RR's Ravi Bishnoi (9). His spell reduced LSG to a below-par 164/8, setting up GT's comfortable 7-wicket chase.",
      "tag": "On Fire"
    },
    {
      "id": "gt-bounce-back-second-win",
      "title": "GT's second straight win — Buttler 60, Gill 56 chase down LSG at Ekana with 8 balls to spare",
      "body": "After a poor start to IPL 2026 (0-2), Gujarat Titans have now won two in a row. Jos Buttler's 60 and skipper Shubman Gill's 56 powered a cruise-control chase of 165 in 18.4 overs against LSG on April 12. GT move up to 5th with 4 points, while LSG tumble to 6th after their second straight loss.",
      "tag": "Breakout"
    },
    {
      "id": "rr-still-perfect-srh-next",
      "title": "RR still flawless at 4-0 — unbeaten leaders travel to Hyderabad tonight for SRH showdown",
      "body": "Rajasthan Royals top the table with a perfect 4-0 record and +2.055 NRR, two points clear of Punjab Kings. Vaibhav Sooryavanshi leads the Orange Cap (200 runs at SR 266.67) and Ravi Bishnoi sits 2nd on the Purple Cap list (9 wkts). Tonight (April 13) they face a struggling SRH at the Rajiv Gandhi Stadium with a chance to become the first side to go 5-0 in IPL 2026.",
      "tag": "On Fire"
    },
    {
      "id": "patidar-orange-cap-surge",
      "title": "Patidar explodes into Orange Cap top 3 — 53 off 20 at Wankhede makes him 2nd fastest scorer",
      "body": "RCB captain Rajat Patidar came within a whisker of the fastest IPL fifty at Wankhede, getting there off 17 balls on his way to 53 off 20. He now has 195 runs in 4 innings at a strike rate of 214.28 — leapfrogging Yashasvi Jaiswal into 2nd on the Orange Cap list, behind only 15-year-old sensation Vaibhav Sooryavanshi (200).",
      "tag": "Sensation"
    },
    {
      "id": "kkr-still-winless-after-match-20",
      "title": "KKR's crisis deepens — still 0 wins from 4, anchored to bottom as every other team tastes victory",
      "body": "Even after Match 20, Kolkata Knight Riders remain the only team in IPL 2026 without a single win on the field. They sit 10th with 1 point (a washout against PBKS in Match 12), while the Rs.25.2 crore Cameron Green, Rs.18 crore Matheesha Pathirana and Rs.9.2 crore Mustafizur Rahman have yet to fire. KKR travel to Chepauk on April 14 to face Sanju Samson's revived CSK.",
      "tag": "Crisis"
    }
  ],
